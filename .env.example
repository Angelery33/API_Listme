# ── Base de datos ─────────────────────────────────────────────────────────────
# URL de conexión JDBC a PostgreSQL
LISTME_DB_URL=jdbc:postgresql://postgres:5432/list_me
# Usuario de la base de datos
LISTME_DB_USERNAME=
# Contraseña de la base de datos
LISTME_DB_PASSWORD=

# ── JPA ───────────────────────────────────────────────────────────────────────
# Estrategia de Hibernate: "update" en desarrollo, "validate" en producción
LISTME_JPA_DDL_AUTO=update

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Cadena hexadecimal aleatoria de mínimo 64 caracteres (256 bits)
# Generar con: openssl rand -hex 32
LISTME_JWT_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma, sin wildcards en producción
LISTME_CORS_ORIGINS=https://app.angelcantero.store,http://localhost:3000

# ── Bootstrap admin ───────────────────────────────────────────────────────────
# Solo se crea el usuario si ambas variables están definidas y no vacías
# Si el usuario ya existe en la BD se ignora
LISTME_BOOTSTRAP_USERNAME=
LISTME_BOOTSTRAP_PASSWORD=
